NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

AUTH_USER=admin
AUTH_PASS=change-me-to-a-long-password
API_KEY=change-me-to-a-random-secret
AUTH_COOKIE_SECURE=true

HERMES_DB_PATH=/var/lib/hermes-dashboard/hermes.db
HERMES_STATE_DIR=/var/lib/hermes-dashboard/state
HERMES_CODING_STORAGE_DIR=/var/lib/hermes-dashboard/state/coding

HERMES_ALLOW_POLICY_WRITE=false
HERMES_ALLOW_CRON_WRITE=false
HERMES_ALLOW_WORKSPACE_WRITE=true

HERMES_HOST_LOCK=off
HERMES_OPENCLAW_HOME=/home/hermes/.openclaw
HERMES_DEFAULT_INSTANCE=default

HERMES_1PASSWORD_MODE=auto
HERMES_OP_ENV_FILE=/etc/hermes-dashboard/hermes-dashboard.op.env

# Optional OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://dashboard.example.com/api/auth/google/callback

# Optional integrations
# PLAUSIBLE_SITE_ID=
# PLAUSIBLE_API_KEY=
# MAILCHIMP_API_KEY=
# GA4_PROPERTY_ID=
# GA4_SERVICE_ACCOUNT_JSON=
# X_BEARER_TOKEN=
# X_USERNAME=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_URN=