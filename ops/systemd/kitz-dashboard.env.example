NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

AUTH_USER=admin
AUTH_PASS=change-me-to-a-long-password
API_KEY=change-me-to-a-random-secret
AUTH_COOKIE_SECURE=true

KITZ_DB_PATH=/var/lib/kitz-dashboard/kitz.db
KITZ_STATE_DIR=/var/lib/kitz-dashboard/state
KITZ_CODING_STORAGE_DIR=/var/lib/kitz-dashboard/state/coding

KITZ_ALLOW_POLICY_WRITE=false
KITZ_ALLOW_CRON_WRITE=false
KITZ_ALLOW_WORKSPACE_WRITE=true

KITZ_HOST_LOCK=off
KITZ_OPENCLAW_HOME=/home/kitz/.openclaw
KITZ_DEFAULT_INSTANCE=default

KITZ_1PASSWORD_MODE=auto
KITZ_OP_ENV_FILE=/etc/kitz-dashboard/kitz-dashboard.op.env

# Optional OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://dashboard.example.com/api/auth/google/callback

# Optional integrations
# PLAUSIBLE_SITE_ID=
# PLAUSIBLE_API_KEY=
# MAILCHIMP_API_KEY=
# GA4_PROPERTY_ID=
# GA4_SERVICE_ACCOUNT_JSON=
# X_BEARER_TOKEN=
# X_USERNAME=
# LINKEDIN_ACCESS_TOKEN=
# LINKEDIN_ORGANIZATION_URN=